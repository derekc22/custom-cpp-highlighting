{
	"name": "custom-cpp-dark-private",
	"type": "dark",
	"colors": {
		"editor.background": "#2B2B2B",
		"editor.foreground": "#D4DBE3",
		"activityBarBadge.background": "#007acc",
		"sideBarTitle.foreground": "#bbbbbb",
		"activityBar.background": "#2B2B2B",
		"activityBar.border": "#696969",
		"debugToolBar.background": "#2B2B2B",
		"debugToolBar.border": "#696969",
		"sideBar.background": "#2B2B2B",
		"sideBar.border": "#696969"
	},
	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment.line.double-slash.cpp"
			],
			"settings": {
				"foreground": "#999999"
			}
		},
		{
			"name": "Block Comments",
			"scope": [
				"comment.block.cpp",
				"comment.block.documentation",
				"comment.block.documentation.cpp",
				"punctuation.definition.comment.begin.documentation.cpp",
				"punctuation.definition.comment.end.documentation.cpp"
			],
			"settings": {
				"foreground": "#4f992d"
			}
		},
		{
			"name": "Doxygen Tags",
			"scope": [
				"storage.type.class.doxygen.cpp"
			],
			"settings": {
				"foreground": "#BAAF29",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"string constant.other.placeholder"
			],
			"settings": {
				"foreground": "#D4DBE3"
			}
		},
		// {
		// 	"name": "Member Access Punctuation",
		// 	"scope": [
		// 		"punctuation.separator.dot-access",
		// 		"punctuation.separator.pointer-access"
		// 	],
		// 	"settings": {
		// 		"foreground": "#f17c7c"
		// 	}
		// },
		{
			"name": "Member Variables",
			"scope": [
				"variable.other.member.cpp",
				"variable.other.property.cpp",
				"variable.other.member.readwrite",
				"variable.other.property.readwrite",
				"entity.name.variable.member",
				"entity.name.variable.member.cpp",
				"entity.name.variable.property",
				"entity.name.variable.property.cpp"
			],
			"settings": {
				"foreground": "#f17c7c"
			}
		},
		{
			"name": "Variable Parameters",
			"scope": [
				"variable.parameter.cpp"
			],
			"settings": {
				"foreground": "#999999"
			}
		},
		{
			"name": "Primitive Types",
			"scope": [
				"storage.type.primitive.cpp",
				"storage.type.built-in.primitive.cpp"
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "Defined Types",
			"scope": [
				"storage.type",
				"entity.name.type",
				"entity.name.type.class",
				"entity.name.type.cpp",
				"entity.name.type.template.cpp",
				"support.type.posix-reserved",
				"entity.name.type.struct"
			],
			"settings": {
				"foreground": "#D4DBE3"
			}
		},
		{
			"name": "Type Keywords",
			"scope": [
				"storage.type.class.cpp",
				"storage.type.struct.cpp",
				"keyword.other.typedef.cpp",
				"storage.type.template.cpp",
				"storage.type.template.argument.typename",
				"storage.type.template.argument.class"
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "Class Variables",
			"scope": [
				"variable.language.this"
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "Namespace Identifiers",
			"scope": [
				"entity.name.namespace",
				"entity.name.namespace.cpp",
				"entity.name.namespace.alias",
				"entity.name.namespace.scope-resolution",
				"entity.name.namespace.scope-resolution.cpp",
				"entity.name.namespace.qualifier",
				"entity.name.scope-resolution.namespace.using.cpp",
				"entity.name.scope-resolution.cpp",
				"entity.name.type.namespace",
				"entity.name.type.namespace.cpp",
				"entity.other.namespace",
				"entity.other.namespace.cpp",
				"support.type.namespace"
			],
			"settings": {
				"foreground": "#67dbc4"
			}
		},
		{
			"name": "Namespace Keywords",
			"scope": [
				"keyword.other.using.directive",
				"keyword.other.namespace.directive storage.type.namespace.directive",
				"storage.type.namespace.definition"
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "Control Keywords",
			"scope": [
				"keyword.control",
				"keyword.control.if.cpp",
				"keyword.control.else.cpp",
				"keyword.control.return.cpp"
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "Exceptions",
			"scope": [
				"keyword.control.exception"
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "Preprocessor Directives",
			"scope": [
				"keyword.control.directive",
				"keyword.control.directive.conditional.cpp",
				"keyword.control.directive.include.cpp",
				"keyword.control.directive.define.cpp"
			],
			"settings": {
				"foreground": "#BAAF29"
			}
		},
		{
			"name": "Preprocessor Values",
			"scope": [
				"entity.name.function.preprocessor.cpp"
			],
			"settings": {
				"foreground": "#c941db"
			}
		},
		{
			"name": "Modifier Keywords",
			"scope": [
				"storage.modifier.specifier",
				"storage.modifier.specifier.const.cpp",
				"storage.modifier.specifier.static.cpp",
				"storage.modifier.specificer.functional.pre-parameters",
				"storage.modifier.specificer.functional.post-parameters",
				"storage.type.modifier.access.control",
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "Functions",
			"scope": [
				"entity.name.function.cpp",
				"entity.name.function.call.cpp",
				"entity.name.function.member.cpp"
			],
			"settings": {
				"foreground": "#f3974b",
			}
		},
		{
			"name": "Math Operators",
			"scope": [
				"keyword.operator",
				"keyword.operator.cpp",
				"keyword.operator.arithmetic.cpp",
				"keyword.operator.comparison.cpp",
				"keyword.operator.assignment.cpp",
				"keyword.operator.logical.cpp"
			],
			"settings": {
				"foreground": "#D4DBE3"
			}
		},
		{
			"name": "Bitwise Shift Operators",
			"scope": [
				"keyword.operator.bitwise.shift.cpp"
			],
			"settings": {
				"foreground": "#6EA09D"
			}
		},
		{
			"name": "Casts",
			"scope": [
				"keyword.operator.cast"
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "Memory Operators",
			"scope": [
				"keyword.operator.memory",
				"keyword.operator.new.cpp",
				"keyword.operator.delete.array",
				"keyword.operator.delete.array.bracket"
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "Reference Operators",
			"scope": [
				"storage.modifier.reference.cpp"
			],
			"settings": {
				"foreground": "#6EA09D"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"string.quoted.double.include.cpp",
				"string.quoted.double.cpp"
			],
			"settings": {
				"foreground": "#82A06E",
			}
		},
		{
			"name": "Numeric Constants",
			"scope": [
				"constant.numeric",
				"constant.numeric.decimal",
				"constant.numeric.hexadecimal",
				"punctuation.separator.constant.numeric",
				"keyword.other.unit.hexadecimal",
				"constant.numeric.decimal.point",
				"keyword.other.unit.suffix.floating-point",
				"keyword.other.unit.binary",
				"constant.numeric.binary",
				"keyword.other.unit.octal",
				"constant.numeric.octal",
				"keyword.other.unit.suffix.integer",
				"keyword.other.unit.user-defined"
			],
			"settings": {
				"foreground": "#b5cea8"
			}
		},
		{
			"name": "Built-in Constants",
			"scope": [
				"constant.language.cpp"
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "Other Constants",
			"scope": [
				"constant.language"
			],
			"settings": {
				"foreground": "#b5cea8"
			}
		},
		{
			"name": "CMake Keywords and Variables",
			"scope": [
				"keyword.cmake",
				"storage.source.cmake"
			],
			"settings": {
				"foreground": "#99C6EC"
			}
		},
		{
			"name": "CMake Entities",
			"scope": [
				"entity.source.cmake"
			],
			"settings": {
				"foreground": "#9cdcfe"
			}
		}
	]
}